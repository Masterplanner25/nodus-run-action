import "std:test" as test

test.suite("core language", fn() {
    test.case("arithmetic", fn() {
        test.assert_eq(1 + 1, 2)
    })
    test.case("string interpolation", fn() {
        let name = "Nodus"
        test.assert_eq("\(name) CI", "Nodus CI")
    })
    test.case("list len", fn() {
        let xs = [1, 2, 3]
        test.assert_eq(len(xs), 3i)
    })
    test.case("map access", fn() {
        let m = {"key": 42i}
        test.assert_eq(m["key"], 42i)
    })
    test.case("boolean logic", fn() {
        test.assert(true && !false)
    })
})

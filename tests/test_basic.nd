// Smoke tests for nodus-run-action — exercises core language features.
// nodus test runs this file and fails if any throw is reached.

let x = 1 + 1
if (x != 2) {
    throw "arithmetic: expected 2, got \(x)"
}

let items = [1, 2, 3]
if (len(items) != 3) {
    throw "len(): expected 3, got \(len(items))"
}

let name = "Nodus"
if ("\(name) CI" != "Nodus CI") {
    throw "string interpolation broken"
}

let m = {"key": 42i}
if (m["key"] != 42i) {
    throw "map access broken"
}

print("all checks passed")
